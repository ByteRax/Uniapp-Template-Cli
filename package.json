{
  "name": "uniapp-template-cli",
  "type": "module",
  "version": "1.0.2025121201",
  "packageManager": "pnpm@10.25.0",
  "description": "由 uniapp + Vue3 + Ts + Vite5 + UnoCss 构成的开发模板",
  "author": "Tanranran",
  "license": "MIT",
  "keywords": [
    "uni-app",
    "vue3",
    "typescript",
    "template"
  ],
  "versionCode": "2025121201",
  "gitHash": "97d0392",
  "buildDate": "2025-12-12 14:11:51",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.12.4"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "uvm": "npx @dcloudio/uvm@latest",
    "dev:app": "pnpm type-check && uni -p app",
    "dev:app:test": "pnpm type-check && uni -p app --mode test",
    "dev:app:prod": "pnpm type-check && uni -p app --mode production",
    "dev:app-android": "pnpm type-check && uni -p app-android",
    "dev:app-ios": "pnpm type-check && uni -p app-ios",
    "dev:custom": "pnpm type-check && uni -p",
    "port:free": "node ./scripts/force-kill-port.mjs",
    "dev:h5": "pnpm run port:free -- --mode development && pnpm type-check && uni",
    "dev:h5:production": "pnpm run port:free -- --mode production && pnpm type-check && uni --mode production",
    "dev:h5:ssr": "pnpm run port:free -- --mode development && pnpm type-check && uni --ssr",
    "dev:mp-alipay": "pnpm type-check && uni -p mp-alipay",
    "dev:mp-baidu": "pnpm type-check && uni -p mp-baidu",
    "dev:mp-jd": "pnpm type-check && uni -p mp-jd",
    "dev:mp-kuaishou": "pnpm type-check && uni -p mp-kuaishou",
    "dev:mp-lark": "pnpm type-check && uni -p mp-lark",
    "dev:mp-qq": "pnpm type-check && uni -p mp-qq",
    "dev:mp-toutiao": "pnpm type-check && uni -p mp-toutiao",
    "dev:mp-harmony": "pnpm type-check && uni -p mp-harmony",
    "dev:mp-weixin": "pnpm type-check && uni -p mp-weixin",
    "dev:mp-weixin:production": "pnpm type-check && uni -p mp-weixin --mode production",
    "dev:mp-xhs": "pnpm type-check && uni -p mp-xhs",
    "dev:quickapp-webview": "pnpm type-check && uni -p quickapp-webview",
    "dev:quickapp-webview-huawei": "pnpm type-check && uni -p quickapp-webview-huawei",
    "dev:quickapp-webview-union": "pnpm type-check && uni -p quickapp-webview-union",
    "build:custom": "uni build -p",
    "build:h5": "uni build",
    "build:h5:ssr": "uni build --ssr",
    "build:mp-alipay": "uni build -p mp-alipay",
    "build:mp-baidu": "uni build -p mp-baidu",
    "build:mp-jd": "uni build -p mp-jd",
    "build:mp-kuaishou": "uni build -p mp-kuaishou",
    "build:mp-lark": "uni build -p mp-lark",
    "build:mp-qq": "uni build -p mp-qq",
    "build:mp-toutiao": "uni build -p mp-toutiao",
    "build:mp-harmony": "uni build -p mp-harmony",
    "build:mp-weixin": "uni build -p mp-weixin",
    "build:mp-weixin:production": "uni build -p mp-weixin --mode production",
    "build:mp-xhs": "uni build -p mp-xhs",
    "build:quickapp-webview": "uni build -p quickapp-webview",
    "build:quickapp-webview-huawei": "uni build -p quickapp-webview-huawei",
    "build:quickapp-webview-union": "uni build -p quickapp-webview-union",
    "upload:mp": "node ./scripts/upload-weixin.js",
    "type-check": "vue-tsc -p tsconfig.typecheck.json --noEmit",
    "format": "oxfmt -c .oxfmtrc.json .",
    "format:check": "oxfmt -c .oxfmtrc.json --check .",
    "lint": "oxlint -c .oxlintrc.json --disable-nested-config . && eslint \"src/**/*.vue\"",
    "lint:fix": "oxfmt -c .oxfmtrc.json . && oxlint -c .oxlintrc.json --disable-nested-config --fix . && eslint \"src/**/*.vue\" --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-app-harmony": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-app-plus": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-components": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-h5": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-mp-alipay": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-mp-baidu": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-mp-harmony": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-mp-jd": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-mp-kuaishou": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-mp-lark": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-mp-qq": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-mp-toutiao": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-mp-weixin": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-mp-xhs": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-quickapp-webview": "3.0.0-alpha-5000120260211001",
    "dayjs": "^1.11.19",
    "pinia": "3.0.3",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.4.21",
    "wot-design-uni": "^1.13.0",
    "z-paging": "2.8.8"
  },
  "devDependencies": {
    "@binbinji/unplugin-compress-json": "^0.1.1",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-5000120260211001",
    "@dcloudio/uni-stacktracey": "3.0.0-alpha-5000120260211001",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5000120260211001",
    "@uni-helper/eslint-config": "^0.6.1",
    "@uni-helper/plugin-uni": "^0.1.0",
    "@uni-helper/uni-app-types": "1.0.0-alpha.7",
    "@uni-helper/uni-types": "1.0.0-alpha.7",
    "@uni-helper/unocss-preset-uni": "^0.2.11",
    "@uni-helper/vite-plugin-uni-components": "^0.2.6",
    "@uni-helper/vite-plugin-uni-manifest": "^0.2.12",
    "@uni-helper/vite-plugin-uni-pages": "^0.3.23",
    "@uni-ku/bundle-optimizer": "^2.1.1",
    "@uni-ku/root": "^1.4.1",
    "@unocss/eslint-plugin": "^66.5.10",
    "@vue/runtime-core": "^3.4.21",
    "@vue/tsconfig": "^0.5.1",
    "code-inspector-plugin": "^1.3.3",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "miniprogram-api-typings": "^5.0.0",
    "miniprogram-ci": "^2.1.26",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "1.77.8",
    "sass-loader": "10.4.1",
    "typescript": "^5.9.3",
    "uni-mini-ci": "^0.0.11",
    "unocss": "66.0.0",
    "unocss-applet": "0.12.2",
    "unplugin-auto-import": "20.0.0",
    "vite": "^5.2.8",
    "vite-plugin-imagemin": "^0.6.1",
    "vite-plugin-restart": "^1.0.0",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.1.8"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "oxfmt -c .oxfmtrc.json",
      "oxlint -c .oxlintrc.json --disable-nested-config --fix"
    ],
    "*.vue": [
      "oxfmt -c .oxfmtrc.json",
      "oxlint -c .oxlintrc.json --disable-nested-config --fix",
      "eslint --fix"
    ],
    "*.{json,css,scss,md}": [
      "oxfmt -c .oxfmtrc.json"
    ]
  }
}
